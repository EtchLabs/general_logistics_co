# General Logistics Co — environment template
# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=glc
POSTGRES_PASSWORD=glc_dev_password
POSTGRES_DB=glc

# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=glc
MONGO_PASSWORD=glc_dev_password
MONGO_DB=glc
MONGO_URI=mongodb://glc:glc_dev_password@mongo:27017/glc?authSource=admin

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# API Gateway
JWT_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
API_GATEWAY_PORT=8080

# Microservice ports
CUSTOMER_SERVICE_PORT=8001
PRODUCT_SERVICE_PORT=8002
ORDER_SERVICE_PORT=8003
INVENTORY_SERVICE_PORT=8004
FULFILLMENT_SERVICE_PORT=8005
SHIPPING_SERVICE_PORT=8006
PAYMENT_SERVICE_PORT=8007
TAX_SERVICE_PORT=8008
SUPPLIER_SERVICE_PORT=8009
ACCOUNTING_SERVICE_PORT=8010
HR_PAYROLL_SERVICE_PORT=8011
NOTIFICATION_SERVICE_PORT=8012
REPORTING_SERVICE_PORT=8013
WEBSITE_PORT=8000
CUSTOMER_SIMULATOR_HEALTH_PORT=8020
PUBLIC_DEMO_PORT=8021

# Gateway downstream URLs (used inside Docker network)
CUSTOMER_SERVICE_URL=http://customer_service:8001
PRODUCT_SERVICE_URL=http://product_service:8002
ORDER_SERVICE_URL=http://order_service:8003
INVENTORY_SERVICE_URL=http://inventory_service:8004
FULFILLMENT_SERVICE_URL=http://fulfillment_service:8005
SHIPPING_SERVICE_URL=http://shipping_service:8006
PAYMENT_SERVICE_URL=http://payment_service:8007
TAX_SERVICE_URL=http://tax_service:8008
SUPPLIER_SERVICE_URL=http://supplier_service:8009
ACCOUNTING_SERVICE_URL=http://accounting_service:8010
HR_PAYROLL_SERVICE_URL=http://hr_payroll_service:8011
NOTIFICATION_SERVICE_URL=http://notification_service:8012
REPORTING_SERVICE_URL=http://reporting_service:8013

# Simulators — ~1 order every 5-10 seconds (~480/hr, high daily revenue)
SIMULATOR_ORDER_INTERVAL_MIN_SECONDS=5
SIMULATOR_ORDER_INTERVAL_MAX_SECONDS=10
SIMULATOR_NEW_CUSTOMER_PCT=12
SUPPLIER_POLL_INTERVAL_SECONDS=30

# Seed scripts (host)
API_GATEWAY_URL=http://localhost:8080
